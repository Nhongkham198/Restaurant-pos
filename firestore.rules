rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'zowamarketing@gmail.com' && request.auth.token.email_verified == true
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Helpers ---

    function isValidUserList(data) {
      return data.value is list && data.value.size() <= 100 
        && (data.value.size() == 0 || (data.value[0].username is string && data.value[0].username.size() <= 50));
    }

    function isValidBranchList(data) {
      return data.value is list && data.value.size() <= 10 
        && (data.value.size() == 0 || (data.value[0].name is string && data.value[0].name.size() <= 100));
    }

    function isValidActiveOrder(data) {
      return data.id is number 
        && data.status in ['pending_payment', 'waiting', 'cooking', 'served', 'completed', 'cancelled']
        && data.tableId is number
        && data.items is list && data.items.size() <= 50
        && data.orderTime is number;
    }

    // --- Rules ---

    // Security Rules catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Collections
    match /users/data {
      allow read: if true;
      allow write: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    match /branches/data {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /branches/list/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leaveRequests/data {
      allow read: if isAdmin();
      allow write: if isSignedIn() && (isAdmin() || incoming().value is list);
    }

    match /leaveRequests/{requestId} {
      allow read: if isAdmin() || isSignedIn();
      allow write: if isSignedIn();
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    // Branch Context
    match /branches/{branchId} {
      
      // Allow read access to branch data if signed in or customer
      allow read: if true;
      allow write: if isAdmin();

      // Generic settings subcollection fallback/wildcard for primitives (e.g. logo, openingTime, qrPopup, etc.)
      match /{settingsCollection}/data {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Tables (Collection style)
      match /tables/{tableId} {
        allow read: if true;
        allow write: if isSignedIn() || isAdmin();
      }
      match /tables/data {
        allow read: if true;
        allow write: if isSignedIn() || isAdmin();
      }

      // Menu Items (Document & Collection style)
      match /menuItems/data {
        allow read: if true;
        allow write: if isAdmin();
      }
      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Recipes (Collection style)
      match /recipes/{recipeId} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }
      match /recipes/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }

      // Active Orders (Collection style)
      match /activeOrders/{orderId} {
        allow read: if true; // Customers need to read their orders
        allow create: if isValidActiveOrder(incoming()); // Allow unauthenticated order creation with strict validation
        allow update: if isSignedIn() || isAdmin(); 
        allow delete: if isAdmin();
      }

      // Pre-Orders
      match /preOrders/{orderId} {
        allow read: if true;
        allow create: if true;
        allow update: if isSignedIn() || isAdmin();
      }

      // Stock Items
      match /stockItems/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }
      match /stockItems/{itemId} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }

      // Stock Logs
      match /stockLogs/{logId} {
        allow read: if isAdmin();
        allow create: if isSignedIn();
      }

      // Print History
      match /printHistory/{id} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }
      match /printHistory/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }

      // Staff Calls
      match /staffCalls/{id} {
        allow read: if true;
        allow write: if true;
      }
      match /staffCalls/data {
        allow read: if true;
        allow write: if true;
      }

      // Time Records
      match /timeRecords/{id} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }
      match /timeRecords/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }

      // Payroll Records
      match /payrollRecords/{id} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }
      match /payrollRecords/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }

      // Stock Tags
      match /stockTags/{id} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }
      match /stockTags/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }

      // Maintenance Items
      match /maintenanceItems/{id} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }
      match /maintenanceItems/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }

      // Closing Checklist Templates and Submissions
      match /closingChecklistItems/{id} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }
      match /closingChecklistItems/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }
      match /closingChecklistLog/{id} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }
      match /closingChecklistLog/data {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isSignedIn() || isAdmin();
      }
    }

    // Connection testing
    match /test/connection {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
