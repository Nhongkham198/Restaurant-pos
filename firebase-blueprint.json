{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a staff member or admin in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "branch-admin", "pos", "kitchen", "auditor", "table", "staff"] },
        "allowedBranchIds": { "type": "array", "items": { "type": "number" } },
        "assignedTableId": { "type": "number" },
        "profilePictureUrl": { "type": "string" },
        "fcmTokens": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "username", "role"]
    },
    "Branch": {
      "title": "Branch",
      "description": "Represents a restaurant location.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "lineMessagingToken": { "type": "string" },
        "lineUserId": { "type": "string" },
        "telegramBotToken": { "type": "string" },
        "telegramChatId": { "type": "string" },
        "geminiApiKey": { "type": "string" },
        "qrPopupEnabled": { "type": "boolean" },
        "qrPopupImageUrl": { "type": "string" },
        "qrPopupMessage": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "A food or drink item on the menu.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "nameEn": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "isVisible": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "category"]
    },
    "ActiveOrder": {
      "title": "Active Order",
      "description": "An order currently being processed (waiting, cooking, served).",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "orderNumber": { "type": "number" },
        "status": { "type": "string", "enum": ["pending_payment", "waiting", "cooking", "served", "completed", "cancelled"] },
        "tableId": { "type": "number" },
        "tableName": { "type": "string" },
        "items": { "type": "array" },
        "orderTime": { "type": "number" },
        "branchId": { "type": "number" }
      },
      "required": ["id", "orderNumber", "status", "tableId", "items", "orderTime"]
    },
    "StockItem": {
      "title": "Stock Item",
      "description": "An ingredient or supply item in the inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "reorderPoint": { "type": "number" },
        "lastUpdated": { "type": "number" }
      },
      "required": ["id", "name", "quantity", "unit"]
    },
    "StockLog": {
      "title": "Stock Log",
      "description": "A record of an inventory transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stockItemId": { "type": "number" },
        "action": { "type": "string" },
        "changeDetails": { "type": "string" },
        "performedBy": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "stockItemId", "action", "timestamp"]
    },
    "PreOrder": {
      "title": "Pre Order",
      "description": "An order submitted by a customer via a link, awaiting staff assignment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "assigned", "cancelled"] },
        "timestamp": { "type": "number" },
        "branchId": { "type": "number" },
        "notes": { "type": "string" },
        "totalAmount": { "type": "number" }
      },
      "required": ["id", "customerName", "items", "status", "timestamp", "branchId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Global user accounts stored as individual documents."
    },
    "branches/{branchId}": {
      "schema": "Branch",
      "description": "Global branch configurations stored as individual documents."
    },
    "leaveRequests/{leaveRequestId}": {
      "schema": "LeaveRequest",
      "description": "Global employee leave requests stored as individual documents."
    },
    "branches/{branchId}/tables/{tableId}": {
      "schema": "object",
      "description": "Branch-specific dining tables layout."
    },
    "branches/{branchId}/menuItems/{itemId}": {
      "schema": "MenuItem",
      "description": "Branch-specific menu items database."
    },
    "branches/{branchId}/recipes/{recipeId}": {
      "schema": "object",
      "description": "Branch-specific food recipes."
    },
    "branches/{branchId}/activeOrders/{orderId}": {
      "schema": "ActiveOrder",
      "description": "Active orders for a branch."
    },
    "branches/{branchId}/preOrders/{orderId}": {
      "schema": "PreOrder",
      "description": "Pre-orders submitted by customers."
    },
    "branches/{branchId}/stockItems/{itemId}": {
      "schema": "StockItem",
      "description": "Branch-specific raw material inventory."
    },
    "branches/{branchId}/stockLogs/{logId}": {
      "schema": "StockLog",
      "description": "Inventory change logs."
    },
    "branches/{branchId}/printHistory/{id}": {
      "schema": "object",
      "description": "Branch-specific kitchen/cashier printer receipts log."
    },
    "branches/{branchId}/staffCalls/{id}": {
      "schema": "object",
      "description": "Branch-specific dynamic customer assistance requests."
    },
    "branches/{branchId}/timeRecords/{id}": {
      "schema": "object",
      "description": "Branch HR check-in/out time attendance."
    },
    "branches/{branchId}/payrollRecords/{id}": {
      "schema": "object",
      "description": "Branch HR payroll receipts records."
    },
    "branches/{branchId}/stockTags/{id}": {
      "schema": "object",
      "description": "Branch active stock bar tags tracking."
    },
    "branches/{branchId}/maintenanceItems/{id}": {
      "schema": "object",
      "description": "Repair/maintenance tracking items."
    }
  }
}
